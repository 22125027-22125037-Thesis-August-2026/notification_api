# ============================================================
# uMatter Notification Service — Environment Variables Example
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# ---- Server ----
SERVER_PORT=8080

# ---- PostgreSQL (in-app notification inbox) ----
# Host port 5436 per the uMatter Azure port map (avoids collisions with Therapist/Backend/Social DBs).
DB_URL=jdbc:postgresql://localhost:5436/notification
DB_USERNAME=notification
DB_PASSWORD=notification
# When running via docker compose, set DB_URL=jdbc:postgresql://notification-postgres:5432/notification

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ---- Redis (idempotency cache) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- SMTP (outbound email) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-app-password

# ---- Email "from" identity ----
MAIL_FROM=no-reply@umatter.app
MAIL_FROM_NAME=uMatter

# ---- pgAdmin (local DB UI on host port 5054) ----
# Note: pgAdmin rejects .local / .test / reserved TLDs in its email validator.
PGADMIN_EMAIL=admin@umatter.app
PGADMIN_PASSWORD=admin

# ---- Firebase Cloud Messaging ----
# Set FIREBASE_ENABLED=false in local dev if you do not have credentials.
FIREBASE_ENABLED=true
# Absolute path INSIDE the container (or host) to the service-account JSON.
# In docker-compose this is mounted from ./secrets/firebase-credentials.json -> /app/secrets/firebase-credentials.json
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-credentials.json

# ---- JWT (resource server) ----
# Base64-encoded RSA public key (X.509 SubjectPublicKeyInfo) shared by the Auth service.
# Must match the private key the Auth service uses to sign tokens.
JWT_PUBLIC_KEY=
JWT_ISSUER=mhsa-auth
JWT_AUDIENCE=mhsa-api
